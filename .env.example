# Database (PostgreSQL for production, SQLite for local dev)
# DATABASE_URL=postgresql://user:pass@host:5432/mealrunner
# MEALRUNNER_DB=~/.mealrunner/mealrunner.db  # SQLite override (local only)

# Kroger API (optional — needed for Order tab)
# KROGER_CLIENT_ID=your_client_id
# KROGER_CLIENT_SECRET=your_client_secret
# KROGER_LOCATION_ID=your_store_location_id

# Anthropic API (optional — needed for receipt parsing)
# ANTHROPIC_API_KEY=your_api_key

# Google Sheets (optional — CLI export only)
# GOOGLE_CREDENTIALS_PATH=~/.mealrunner/google_credentials.json

# Server
# PORT=8000
